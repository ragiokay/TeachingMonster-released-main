{
    "openapi": "3.0.0",
    "info": {
      "title": "Teaching Video Generation API",
      "version": "1.0.0"
    },
    "paths": {
      "/v1/video/generate": {
        "post": {
          "summary": "Generate a teaching video",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": { "type": "string" },
                    "course_requirement": { "type": "string" },
                    "student_persona": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Successful generation",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "video_url": { "type": "string" },
                      "subtitle_url": { "type": "string" },
                      "supplementary_url": {
                          "nullable": true,
                          "oneOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          ]
                        }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
